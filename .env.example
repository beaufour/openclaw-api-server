# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_WEBHOOK_TOKEN=your-openclaw-webhook-token

# Asana
# Secret from webhook handshake is auto-persisted to DATA_DIR.
# Set this to override with a known value.
ASANA_WEBHOOK_SECRET=

# Strava
# verify_token: token you choose, passed when creating the Strava subscription
STRAVA_VERIFY_TOKEN=your-strava-verify-token
# webhook_secret: secret path segment in the callback URL
# Register callback as: https://webhooks.yourdomain.com/webhook/strava/<this-value>
STRAVA_WEBHOOK_SECRET=your-strava-webhook-secret

# Gmail Pub/Sub
# Set to your push subscription's audience to enable OIDC JWT validation.
# This is the URL of this server's Gmail webhook endpoint.
GMAIL_PUBSUB_AUDIENCE=https://webhooks.yourdomain.com/webhook/gmail

# Server
HOST=0.0.0.0
PORT=8000

# Data directory for persisted state (e.g., Asana hook secrets)
DATA_DIR=~/.openclaw-api-server
