# Strava
STRAVA_WEBHOOK_SECRET=
STRAVA_VERIFY_TOKEN=

# Asana (auto-persisted from handshake, set here to override)
ASANA_WEBHOOK_SECRET=

# Gmail Pub/Sub (set to your webhook URL to enable JWT validation)
GMAIL_PUBSUB_AUDIENCE=

# Gmail DKIM verification (set to "true" to enable the sender gate)
GMAIL_REQUIRE_DKIM=false
# "monitor" (default): log the DKIM/allowlist verdict but still wake the agent —
#   use this first and watch the logs to confirm legit senders pass.
# "enforce": drop messages that fail DKIM or aren't in the allowlist.
GMAIL_DKIM_MODE=monitor
# authserv-id identifying Gmail's own trusted Authentication-Results header.
# Default mx.google.com fits Gmail/Workspace; override if the logs show another.
GMAIL_TRUSTED_AUTHSERV=mx.google.com

# Server
PORT=18790
DATA_DIR=~/.openclaw-api-server

# OpenClaw Gateway (where wake events are forwarded)
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_HOOK_TOKEN=your-shared-secret
